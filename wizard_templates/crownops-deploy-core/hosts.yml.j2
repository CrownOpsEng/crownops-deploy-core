---
all:
  children:
    core_hosts:
      hosts:
        {{ host_name }}:
          ansible_host: {{ ansible_host | yaml_value }}
          ansible_user: {{ ansible_user | yaml_value }}
          bootstrap_ansible_user: {{ bootstrap_ansible_user | yaml_value }}
{% if ansible_ssh_private_key_file %}
          ansible_ssh_private_key_file: {{ ansible_ssh_private_key_file | yaml_value }}
{% endif %}
