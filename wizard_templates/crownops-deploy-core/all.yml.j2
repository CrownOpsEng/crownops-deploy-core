---
project_name: crownops-deploy-core
base_domain: {{ base_domain | yaml_value }}
ops_domain: {{ ops_domain | yaml_value }}

timezone: {{ timezone | yaml_value }}
bootstrap_target_ubuntu_release: {{ bootstrap_target_ubuntu_release | yaml_value }}

ops_user: {{ ops_user | yaml_value }}
ops_group: {{ ops_group | yaml_value }}

ssh_pubkeys:
{{ ssh_pubkeys | yaml_block(2) }}

vault_root: {{ vault_root | yaml_value }}
exports_root: {{ exports_root | yaml_value }}
local_markdown_workspaces:
{{ local_markdown_workspaces | yaml_block(2) }}

features:
{{ features | yaml_block(2) }}

host:
{{ host | yaml_block(2) }}

tailscale_auth_key: "{{ tailscale_auth_key_ref }}"
tailscale_hostname: {{ tailscale_hostname | yaml_value }}
tailscale_tags: {{ tailscale_tags | yaml_value }}

lockdown_enabled: {{ lockdown_enabled | yaml_value }}
lockdown_confirmed: {{ lockdown_confirmed | yaml_value }}
lockdown_verify_tailscale: {{ lockdown_verify_tailscale | yaml_value }}
lockdown_mode: {{ lockdown_mode | yaml_value }}
lockdown_allowed_cidrs: {{ lockdown_allowed_cidrs | yaml_value }}
lockdown_break_glass_file: {{ lockdown_break_glass_file | yaml_value }}
lockdown_tailscale_interface: {{ lockdown_tailscale_interface | yaml_value }}
lockdown_ssh_port: {{ lockdown_ssh_port | yaml_value }}
lockdown_disable_public_ssh: {{ lockdown_disable_public_ssh | yaml_value }}
lockdown_control_host_probe_enabled: {{ lockdown_control_host_probe_enabled | yaml_value }}
lockdown_control_host_probe_host: {{ lockdown_control_host_probe_host | yaml_value }}
lockdown_control_host_probe_timeout: {{ lockdown_control_host_probe_timeout | yaml_value }}
